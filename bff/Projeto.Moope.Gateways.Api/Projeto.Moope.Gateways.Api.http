@Projeto.Moope.Gateways.Api_HostAddress = https://localhost:7072

### Cadastro composto representante (JWT Administrador)
POST {{Projeto.Moope.Gateways.Api_HostAddress}}/api/bff/representante/cadastro
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Representante Teste",
  "email": "rep@teste.local",
  "tipoPessoa": 2,
  "cpfCnpj": "12345678000199",
  "telefone": "11999999999",
  "ativo": true,
  "endereco": {
    "cep": "01310100",
    "logradouro": "Av Paulista",
    "numero": "1000",
    "bairro": "Bela Vista",
    "cidade": "São Paulo",
    "estado": "SP"
  },
  "nomeFantasia": "Rep Fantasia",
  "inscricaoEstadual": "",
  "percentualComissao": 10,
  "chavePix": "rep@teste.local",
  "status": true,
  "senha": "Senha@123",
  "confirmacao": "Senha@123",
  "codigoCupom": "CUPOM001"
}

###

