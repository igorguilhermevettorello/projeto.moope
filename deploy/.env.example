DOCKERHUB_USER=seu_usuario_dockerhub

# Por padrão, cada serviço usa :latest. Para travar uma versão, preencha com a tag (ex.: 1.0.1).
# BFF_TAG=1.0.1
# AUTH_TAG=1.0.1
# CLIENTE_TAG=1.0.1
# COMODATO_TAG=1.0.1
# EMAIL_TAG=1.0.1
# ENDERECO_TAG=1.0.1
# PAGAMENTO_TAG=1.0.1
# PEDIDO_TAG=1.0.1
# PLANO_TAG=1.0.1
# VENDEDOR_TAG=1.0.1
# RABBITMQ_WORKER_TAG=1.0.1

# RabbitMQ (opcional; se não preencher, usa guest/guest e vhost "/")
# RABBITMQ_DEFAULT_USER=guest
# RABBITMQ_DEFAULT_PASS=guest
# RABBITMQ_DEFAULT_VHOST=/

# RabbitMQ Worker (staging) — broker externo e credenciais do worker
# RABBITMQ_HOST=147.93.70.24
# RABBITMQ_PORT=5673
# RABBITMQ_USER=hml-administrador
# RABBITMQ_PASSWORD=
# RABBITMQ_VHOST=/
# RABBITMQ_WORKER_AUTH_CLIENT_ID=
# RABBITMQ_WORKER_AUTH_CLIENT_SECRET=
# RABBITMQ_WORKER_CLIENTE_API_KEY=

# API Pedido (staging Docker) — URL interna do servico de planos
# PlanoApi__BaseUrl=http://plano:8080
